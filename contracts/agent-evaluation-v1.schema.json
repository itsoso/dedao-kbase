{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kbase.executor.life/contracts/agent-evaluation-v1.schema.json",
  "title": "KBase Agent Evaluation Suite v1",
  "type": "object",
  "required": ["schema_version", "suite_version", "cases"],
  "properties": {
    "schema_version": { "const": "agent-evaluation.v1" },
    "suite_version": { "type": "string", "minLength": 1 },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["case_id", "metric"],
        "properties": {
          "case_id": { "type": "string", "minLength": 1 },
          "metric": {
            "enum": ["retrieval", "retrieval_precision", "citations", "faithfulness", "abstention", "tool_choice", "tool_arguments", "task_completion", "latency", "cost"]
          },
          "input": { "type": "string", "minLength": 1 },
          "expected_ids": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "expected_value": { "type": "string" },
          "model_output": { "type": "string" },
          "proposed_tool": { "type": "string" },
          "proposed_arguments": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "expected_arguments": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "max_latency_ms": { "type": "integer", "minimum": 1 },
          "max_cost_usd": { "type": "number", "exclusiveMinimum": 0 }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
