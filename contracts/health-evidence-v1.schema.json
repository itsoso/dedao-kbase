{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kbase.executor.life/contracts/health-evidence-v1.schema.json",
  "title": "Health Evidence v1",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "release_id", "book_id", "content_hash", "usage_policy", "title", "source", "freshness", "evidence", "created_at"],
  "properties": {
    "schema_version": { "const": "health_evidence.v1" },
    "release_id": { "type": "string", "minLength": 1 },
    "book_id": { "type": "string", "minLength": 1 },
    "content_hash": { "type": "string", "minLength": 1 },
    "usage_policy": { "const": "evidence_only" },
    "title": { "type": "string", "minLength": 1 },
    "summary": { "type": "string" },
    "source": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "uri": { "type": "string" },
        "type": { "type": "string" },
        "account": { "type": "string" },
        "author": { "type": "string" },
        "published_at": { "type": "string" }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": true,
      "required": ["stale"],
      "properties": {
        "published_at": { "type": "string" },
        "age_days": { "type": "integer", "minimum": 0 },
        "stale": { "type": "boolean" }
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["evidence_id", "release_id", "claim_id", "statement", "risk_level", "evidence_level", "citation_ids", "url"],
        "properties": {
          "evidence_id": { "type": "string", "minLength": 1 },
          "release_id": { "type": "string", "minLength": 1 },
          "claim_id": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "risk_level": { "enum": ["low", "medium", "high"] },
          "evidence_level": { "type": "string", "minLength": 1 },
          "scope": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "object", "additionalProperties": true },
          "citation_ids": { "type": "array", "items": { "type": "string" } },
          "citations": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
          "safety_flags": { "type": "array", "items": { "type": "string" } },
          "url": { "type": "string", "minLength": 1 }
        }
      }
    },
    "created_at": { "type": "string", "minLength": 1 }
  }
}
