{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kbase.executor.life/contracts/agent-trace-v1.schema.json",
  "title": "KBase Agent Runtime Trace v1",
  "type": "object",
  "required": [
    "schema_version",
    "trace_id",
    "package",
    "releases",
    "retrievals",
    "model_route",
    "tool_calls",
    "final",
    "started_at",
    "completed_at"
  ],
  "properties": {
    "schema_version": { "const": "agent-trace.v1" },
    "trace_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._-]+$" },
    "package": {
      "type": "object",
      "required": ["package_id", "version", "content_hash"],
      "properties": {
        "package_id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
      },
      "additionalProperties": false
    },
    "releases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["release_id", "version", "content_hash"],
        "properties": {
          "release_id": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "minLength": 1 },
          "content_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        },
        "additionalProperties": false
      }
    },
    "retrievals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_id", "release_id", "score", "rank"],
        "properties": {
          "evidence_id": { "type": "string", "minLength": 1 },
          "release_id": { "type": "string", "minLength": 1 },
          "score": { "type": "number", "minimum": 0 },
          "rank": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    "model_route": {
      "type": "object",
      "required": ["provider", "model", "capability"],
      "properties": {
        "provider": { "type": "string", "minLength": 1 },
        "model": { "type": "string", "minLength": 1 },
        "capability": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "tool_calls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "call_id",
          "mcp_server",
          "tool_name",
          "argument_fingerprint",
          "policy_decision",
          "outcome"
        ],
        "properties": {
          "call_id": { "type": "string", "minLength": 1 },
          "mcp_server": { "type": "string", "minLength": 1 },
          "tool_name": { "type": "string", "minLength": 1 },
          "argument_fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
          "policy_decision": {
            "enum": ["allow", "require_confirmation", "block"]
          },
          "outcome": {
            "enum": [
              "not_executed",
              "succeeded",
              "failed",
              "blocked",
              "confirmation_required"
            ]
          },
          "result_fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        },
        "additionalProperties": false
      }
    },
    "final": {
      "type": "object",
      "required": ["outcome", "response_fingerprint", "citations"],
      "properties": {
        "outcome": { "enum": ["completed", "abstained", "failed"] },
        "response_fingerprint": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "citations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["citation_id", "release_id", "evidence_id"],
            "properties": {
              "citation_id": { "type": "string", "minLength": 1 },
              "release_id": { "type": "string", "minLength": 1 },
              "evidence_id": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "started_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
