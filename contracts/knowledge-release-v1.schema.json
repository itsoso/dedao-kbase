{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kbase.executor.life/contracts/knowledge-release-v1.schema.json",
  "title": "Knowledge Release v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "version",
    "release_id",
    "book_id",
    "content_hash",
    "usage_policy",
    "book",
    "analysis",
    "quality",
    "citations",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "knowledge_release.v1" },
    "version": { "type": "string", "minLength": 1 },
    "release_id": { "type": "string", "minLength": 1 },
    "book_id": { "type": "string", "minLength": 1 },
    "content_hash": { "type": "string", "minLength": 1 },
    "supersedes": { "type": "string" },
    "usage_policy": { "enum": ["standard", "evidence_only"] },
    "book": {
      "type": "object",
      "additionalProperties": true,
      "required": ["book_id", "title"],
      "properties": {
        "book_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "content_hash": { "type": "string" },
        "source_type": { "type": "string" }
      }
    },
    "analysis": { "type": "object", "additionalProperties": true },
    "quality": {
      "type": "object",
      "additionalProperties": true,
      "required": ["decision", "usage_policy", "content_hash"],
      "properties": {
        "decision": { "type": "string", "minLength": 1 },
        "usage_policy": { "enum": ["standard", "evidence_only"] },
        "content_hash": { "type": "string", "minLength": 1 }
      }
    },
    "sources": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
    "citations": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": true } },
    "created_at": { "type": "string", "minLength": 1 }
  }
}
